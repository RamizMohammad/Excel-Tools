{
  "name": "jupyxl",
  "version": "0.1.0",
  "description": "Run a live Jupyter kernel inside Excel and push formatted DataFrames to the grid.",
  "private": true,
  "scripts": {
    "certs": "office-addin-dev-certs install",
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^6.0.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
